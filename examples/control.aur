Int score = 87;
if score >= 90 {
    print("Grade: A");
} else if score >= 80 {
    print("Grade: B");
} else if score >= 70 {
    print("Grade: C");
} else {
    print("Grade: F");
}
Int mut i = 1;
Int mut sum = 0;
while i <= 10 {
    sum := sum + i;
    i   := i + 1;
}
print("Sum 1..10 = " + str(sum));
for n in 1..5 {
    print("n = " + str(n));
}
